{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "exclude": ["exports", "types"],
  "ignoreDependencies": ["tree-sitter-wasms", "@types/*"],
  "workspaces": {
    "packages/core": {
      "project": "src/**/*.ts"
    },
    "packages/cli": {
      "project": "src/**/*.ts"
    },
    "packages/app": {
      "project": ["src/**/*.{ts,tsx}", "tests/**/*.ts"]
    }
  }
}
