{
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "level": {
      "type": "string",
      "enum": [
        "context",
        "container",
        "component",
        "code"
      ]
    },
    "metaData": {
      "type": "object",
      "properties": {
        "entityRef": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-zA-Z0-9_-]+(\\/[a-zA-Z0-9_-]+)*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "name"
      ],
      "additionalProperties": false
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "entityRef": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9_-]+(\\/[a-zA-Z0-9_-]+)*$"
          },
          "type": {
            "type": "string",
            "enum": [
              "person",
              "software-system",
              "web-app",
              "mobile-app",
              "single-page-app",
              "microservice",
              "database",
              "cache-store",
              "event-broker",
              "serverless-app",
              "component",
              "container",
              "code-module",
              "relational-database",
              "grpc-service",
              "serverless-function",
              "rest-api",
              "gateway-api",
              "background-worker"
            ]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "external": {
            "type": "boolean"
          },
          "properties": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "number"
                },
                {
                  "type": "boolean"
                }
              ]
            }
          },
          "isTest": {
            "type": "boolean"
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "forensics": {
            "type": "object",
            "properties": {
              "complexity": {
                "type": "number"
              },
              "loc": {
                "type": "number"
              },
              "sloc": {
                "type": "number"
              },
              "churn": {
                "type": "number"
              },
              "churnByWeek": {
                "type": "array",
                "items": {
                  "type": "number",
                  "minimum": 0
                }
              },
              "authorCount": {
                "type": "number"
              },
              "topAuthorPercent": {
                "type": "number"
              },
              "hotspotScore": {
                "type": "number"
              },
              "classifications": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "hotspot",
                    "knowledge-silo"
                  ]
                }
              },
              "coupledFiles": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "string",
                      "minLength": 1
                    },
                    "score": {
                      "type": "number"
                    },
                    "sharedCommits": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "path",
                    "score",
                    "sharedCommits"
                  ],
                  "additionalProperties": false
                }
              },
              "sinceDays": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "fileCount": {
                "type": "number"
              },
              "hotspotCount": {
                "type": "number"
              },
              "knowledgeSiloCount": {
                "type": "number"
              }
            },
            "additionalProperties": false
          }
        },
        "required": [
          "entityRef",
          "type",
          "name"
        ],
        "additionalProperties": false
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "direct-call",
              "publish-subscribe",
              "read-write",
              "inter-container"
            ]
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "from",
          "to",
          "type"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "version",
    "level",
    "metaData",
    "nodes"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://blueprint.mzworthington.co.uk/schemas/v3/blueprint.schema.json",
  "title": "Blueprint System Schema",
  "description": "Declarative C4 diagram schema used by Blueprint CLI and designer. Root is a YAML mapping: version (schema URL), level, metaData (entityRef, name), nodes, dependencies. Generated from Zod — do not edit by hand."
}
