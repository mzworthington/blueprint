{
  "name": "blueprint",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint -c .oxlintrc.json",
    "preview": "vite preview",
    "test": "vitest run",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\" \"scripts/**/*.ts\" \"*.md\"",
    "format:write": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\" \"scripts/**/*.ts\" \"*.md\"",
    "analyze": "tsx scripts/analyze.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@xyflow/react": "^12.4.2",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.475.0",
    "mermaid": "^11.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.54",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "dagre": "^0.8.5",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.71.0",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.0.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.23.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^3.0.5"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,css,json}": [
      "prettier --write",
      "oxlint -c .oxlintrc.json"
    ],
    "*.md": [
      "prettier --write"
    ]
  }
}
