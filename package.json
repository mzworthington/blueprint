{
  "name": "blueprint",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint -c .oxlintrc.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\" \"cli/**/*.ts\" \"*.md\"",
    "format:write": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\" \"cli/**/*.ts\" \"*.md\"",
    "blueprint": "tsx cli/blueprint.ts",
    "blueprint:compile": "bun build ./cli/blueprint.ts --compile --outfile dist/blueprint-cli",
    "prepare": "husky"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@xyflow/react": "^12.11.2",
    "js-yaml": "^5.2.1",
    "lucide-react": "^1.23.0",
    "mermaid": "^11.16.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "wouter": "^3.10.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.0.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.54",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "dagre": "^0.8.5",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.73.0",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.0.12",
    "tree-sitter-wasms": "0.1.13",
    "ts-morph": "^28.0.0",
    "tsx": "^4.23.0",
    "typescript": "~7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "web-tree-sitter": "0.20.8"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "prettier --check",
      "oxlint -c .oxlintrc.json"
    ],
    "**/*.{css,json,md}": [
      "prettier --check"
    ]
  }
}