{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "exclude": ["exports", "types"],
  "ignoreDependencies": ["lint-staged", "@types/*"],
  "ignoreBinaries": ["vhs"],
  "workspaces": {
    "packages/designer": {
      "project": ["src/**/*.{ts,tsx}", "tests/**/*.ts"],
      "paths": {
        "@docs/*": ["../../../docs/*"]
      }
    }
  }
}
