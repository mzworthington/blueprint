if git diff --cached --name-only | grep -qE '^(cli/|core/proto/)'; then
  echo "Detected changes to CLI or Proto. Running Cargo checks..."
  cd cli
  cargo fmt
  cargo clippy -- -D warnings
  cargo test 
  cd ..
fi

if git diff --cached --name-only | grep -qE '^(app/|core/proto/)'; then
  echo "Detected changes to App or Proto. Running PNPM checks..."
  cd app
  pnpm exec lint-staged
  pnpm run lint
  pnpm vitest run --changed
  pnpm knip
  cd ..
fi
