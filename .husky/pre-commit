if git diff --cached --name-only | grep -qE '^cli/'; then
  echo "Skipping Rust checks — experimental cli/ tree is unmaintained and not part of CI."
fi

if git diff --cached --name-only | grep -qE '^app/'; then
  echo "Detected changes under app/. Running PNPM checks..."
  cd app
  pnpm exec lint-staged
  pnpm run lint
  pnpm vitest run --changed
  pnpm knip
  cd ..
fi
