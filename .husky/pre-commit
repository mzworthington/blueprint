STAGED=$(git diff --cached --name-only)

if echo "$STAGED" | grep -qE '^cli/'; then
  echo "Skipping Rust checks — experimental cli/ tree is unmaintained and not part of CI."
fi

# Fail if Zod → JSON Schema artifacts are stale when core (or generator) changes.
if echo "$STAGED" | grep -qE '^app/packages/core/'; then
  echo "Core package staged — checking schemas/blueprint.schema.json is up to date..."
  (cd app && pnpm --filter @blueprint/core generate:schema -- --check) || {
    echo "Schema out of date. Run: cd app && pnpm generate:schema"
    exit 1
  }
fi

# CI runs format:check on app + repo docs/README. Keep the hook in sync.
NEEDS_APP_CHECKS=false
NEEDS_DOCS_FORMAT=false

if echo "$STAGED" | grep -qE '^app/'; then
  NEEDS_APP_CHECKS=true
fi

if echo "$STAGED" | grep -qE '^docs/|(^|/)[^/]+\.md$'; then
  NEEDS_DOCS_FORMAT=true
fi

if [ "$NEEDS_APP_CHECKS" = true ] || [ "$NEEDS_DOCS_FORMAT" = true ]; then
  echo "Detected staged app/docs changes. Running PNPM checks..."
  cd app
  pnpm exec lint-staged
  # Match CI: full-repo format check, not just auto-fix on staged paths.
  pnpm run format:check
  if [ "$NEEDS_APP_CHECKS" = true ]; then
    pnpm run lint
    pnpm run typecheck
    pnpm knip
    pnpm vitest run --changed
  fi
  cd ..
fi
